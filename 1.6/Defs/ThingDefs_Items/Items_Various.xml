<?xml version="1.0" encoding="utf-8"?>
<Defs>
  
  <ThingDef>
    <defName>NAT_PainClot</defName>
    <label>pain clot</label>
    <description>A piece of clotted pain.</description>
    <thingClass>ThingWithComps</thingClass>
    <tradeability>None</tradeability>
    <category>Item</category>
    <genericMarketSellable>false</genericMarketSellable>
    <drawerType>MapMeshOnly</drawerType>
    <tickerType>Normal</tickerType>
    <rotatable>false</rotatable>
    <altitudeLayer>Item</altitudeLayer>
    <selectable>true</selectable>
    <alwaysHaulable>true</alwaysHaulable>
    <drawGUIOverlay>true</drawGUIOverlay>
    <scatterableOnMapGen>false</scatterableOnMapGen>
    <useHitPoints>false</useHitPoints>
    <healthAffectsPrice>false</healthAffectsPrice>
    <graphicData>
      <texPath>Things/Item/NAT_PainClot</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
      <drawSize>(1, 1)</drawSize>
    </graphicData>
    <soundInteract>Standard_Pickup</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>75</stackLimit>
    <intricate>true</intricate>
    <statBases>
      <Mass>0.05</Mass>
      <Beauty>-10</Beauty>
      <Flammability>0</Flammability>
    </statBases>
    <thingCategories>
      <li>ItemsMisc</li>
    </thingCategories>
    <hiddenWhileUndiscovered>true</hiddenWhileUndiscovered>
    <comps>
      <li Class="CompProperties_Forbiddable" />
    </comps>
  </ThingDef>

  <ThingDef ParentName="ChunkBase">
    <defName>NAT_HoraxChunk</defName>
    <label>dark archochunk</label>
    <description>A chunk of steel slag. While it's useless in its current form, it can be smelted to recover steel.</description>
    <graphicData>
      <texPath>Things/Item/Chunk/ChunkSlag</texPath>
      <graphicClass>Graphic_Random</graphicClass>
    </graphicData>
    <statBases>
      <Mass>10</Mass>
    </statBases>
    <soundDrop>ChunkSlag_Drop</soundDrop>
    <thingCategories>
      <li>Chunks</li>
    </thingCategories>
    <smeltable>true</smeltable>
    <smeltProducts>
      <Steel>15</Steel>
    </smeltProducts>
  </ThingDef>
  
</Defs>