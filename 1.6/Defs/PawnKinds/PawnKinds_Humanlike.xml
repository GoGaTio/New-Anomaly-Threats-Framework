<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <PawnKindDef>
    <defName>NAT_Researcher</defName>
    <label>researcher</label>
    <race>Human</race>
    <combatPower>30</combatPower>
    <defaultFactionDef>Ancients</defaultFactionDef>
    <chemicalAddictionChance>0.06</chemicalAddictionChance>
    <humanPregnancyChance>0</humanPregnancyChance>
    <isFighter>false</isFighter>
    <apparelIgnoreSeasons>true</apparelIgnoreSeasons>
    <apparelIgnorePollution MayRequire="Ludeon.RimWorld.Biotech">true</apparelIgnorePollution>
    <initialWillRange>4~7</initialWillRange>
    <forceNormalGearQuality>true</forceNormalGearQuality>
    <combatEnhancingDrugsChance>0.25</combatEnhancingDrugsChance>
    <combatEnhancingDrugsCount>1</combatEnhancingDrugsCount>
    <apparelRequired>
      <li>Apparel_LabCoat</li>
    </apparelRequired>
    <apparelColor>(250,250,250)</apparelColor>
    <apparelTags>
      <li>IndustrialBasic</li>
    </apparelTags>
    <apparelAllowHeadgearChance>0</apparelAllowHeadgearChance>
    <apparelMoney>750~1200</apparelMoney>
    <backstoryCryptosleepCommonality>1</backstoryCryptosleepCommonality>
    <techHediffsChance>0.23</techHediffsChance>
    <techHediffsMoney>500~1800</techHediffsMoney>
    <techHediffsTags>
      <li>Simple</li>
      <li>Advanced</li>
      <li>ImplantEmpireCommon</li>
    </techHediffsTags>
    <techHediffsDisallowTags>
      <li>PainCauser</li>
    </techHediffsDisallowTags>
    <initialResistanceRange>13~21</initialResistanceRange>
  </PawnKindDef>

  <PawnKindDef ParentName="BasePlayerPawnKind">
    <defName>NAT_PlayerCultist</defName>
    <label>cultist</label>
    <defaultFactionType>NAT_PlayerCult</defaultFactionType>
    <apparelColor>(85, 85, 85)</apparelColor>
    <styleItemTags>
      <li>
        <tag>Cultist</tag>
        <baseWeight>5</baseWeight>
        <weightFactor>1</weightFactor>
      </li>
    </styleItemTags>
    <startingHediffs>
      <li>
        <def>Inhumanized</def>
      </li>
      <li>
        <def>Tentacle</def>
        <chance>0.15</chance>
      </li>
      <li>
        <def>BlissLobotomy</def>
        <chance>0.05</chance>
      </li>
      <li>
        <def>FleshWhip</def>
        <chance>0.05</chance>
      </li>
      <li>
        <def>Metalblood</def>
        <durationTicksRange>60000~300000</durationTicksRange>
        <!-- 1~5 days -->
        <chance>0.05</chance>
      </li>
      <li>
        <def>DeathRefusal</def>
        <chance>0.03</chance>
      </li>
    </startingHediffs>
    <specificApparelRequirements>
      <li>
        <bodyPartGroup>Torso</bodyPartGroup>
        <alternateTagChoices>
          <li>
            <tag>Robe</tag>
            <chance>1</chance>
          </li>
        </alternateTagChoices>
      </li>
      <li>
        <bodyPartGroup>FullHead</bodyPartGroup>
        <requiredTag>HoraxianCeremonial</requiredTag>
        <useRandomStyleDef>true</useRandomStyleDef>
      </li>
      <li>
        <color>(85, 85, 85)</color>
      </li>
    </specificApparelRequirements>
    <requiredWorkTags>
      <li>Violent</li>
    </requiredWorkTags>
    <initialResistanceRange>13~21</initialResistanceRange>
  </PawnKindDef>

</Defs>