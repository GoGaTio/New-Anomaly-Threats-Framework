<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="SignalActionBase">
    <defName>NAT_SignalAction_Sightstealers</defName>
    <thingClass>NAT.SignalAction_Sightstealers</thingClass>
    <tickerType>Normal</tickerType>
  </ThingDef>

  <ThingDef Name="NAT_MovableEntityBase" Abstract="True">
    <thingClass>NAT.MovableEntity</thingClass>
    <selectable>true</selectable>
    <category>None</category>
    <forceDebugSpawnable>true</forceDebugSpawnable>
    <drawerType>RealtimeOnly</drawerType>
    <tickerType>Normal</tickerType>
    <rotatable>false</rotatable>
    <altitudeLayer>Pawn</altitudeLayer>
    <isAutoAttackableMapObject>true</isAutoAttackableMapObject>
    <drawGUIOverlay>true</drawGUIOverlay>
    <useHitPoints>true</useHitPoints>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
    </statBases>
    <modExtensions>
      <li Class="NAT.CanHaveFactionExtension"/>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="SkyfallerBase">
    <defName>NAT_HoraxMachineIncoming</defName>
    <label>horax machine (incoming)</label>
    <skyfaller>
      <movementType>Decelerate</movementType>
      <shadow>Things/Skyfaller/SkyfallerShadowDropPod</shadow>
      <shadowSize>(3, 3)</shadowSize>
      <ticksToImpactRange>200</ticksToImpactRange>
      <rotateGraphicTowardsDirection>true</rotateGraphicTowardsDirection>
      <motesPerCell>0</motesPerCell>
      <angleCurve>
        <points>
          <li>(0,0)</li>
        </points>
      </angleCurve>
      <rotationCurve>
        <points>
          <li>(0,0)</li>
        </points>
      </rotationCurve>
    </skyfaller>
  </ThingDef>
  
</Defs>