<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef Name="NAT_AltarTradeBase" Abstract="True">
    <hediffClass>NAT.HediffAltarTrade</hediffClass>
    <isBad>false</isBad>
    <everCurableByItem>false</everCurableByItem>
    <keepOnBodyPartRestoration>true</keepOnBodyPartRestoration>
    <comps>
      <li Class="HediffCompProperties_DisappearsOnDeath" />
    </comps>
  </HediffDef>

  <HediffDef ParentName="NAT_AltarTradeBase">
    <defName>NAT_HoraxianCurse</defName>
    <label>horaxian curse</label>
    <description>.</description>
  </HediffDef>

  <HediffDef>
    <defName>NAT_Subdued</defName>
    <description>This person is subdued by distant archotech structure.</description>
    <label>subdued</label>
    <hediffClass>NAT.Hediff_Subdued</hediffClass>
    <stages>
      <li>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>7500~12500</disappearsAfterTicks>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>NAT_EmotionSuppression</defName>
    <label>emotions suppression</label>
    <hediffClass>HediffWithComps</hediffClass>
    <description>This person's neural patterns are being moderated by distant archotech structure. They're unaffected by the highs and lows of human emotion. They will never have a mental break but they will also never feel inspired.</description>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_DisappearsDisableable">
        <disappearsAfterTicks>180000</disappearsAfterTicks>
        <!-- 3 days -->
        <showRemainingTime>true</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath" />
    </comps>
    <stages>
      <li>
        <blocksMentalBreaks>true</blocksMentalBreaks>
        <blocksInspirations>true</blocksInspirations>
        <pctAllThoughtNullification>1</pctAllThoughtNullification>
        <overrideMoodBase>0.9</overrideMoodBase>
        <statFactors>
          <PsychicSensitivity>0.7</PsychicSensitivity>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>NAT_PainQuenchSerum</defName>
    <label>pain quench</label>
    <hediffClass>NAT.Hediff_PainQuench</hediffClass>
    <description>This creature has the pain quench serum in their bloodstream. This substance makes it fully resistant to any pain source and additionally suppress induced pain.</description>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_DisappearsDisableable">
        <disappearsAfterTicks>1200000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath" />
    </comps>
    <stages>
      <li>
        <painFactor>0</painFactor>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>NAT_InducedPain</defName>
    <label>induced pain</label>
    <description>A pain without any visible reason.</description>
    <initialSeverity>0.001</initialSeverity>
    <hediffClass>NAT.Hediff_InducedPain</hediffClass>
    <isBad>false</isBad>
    <maxSeverity>10</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>5000~15000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>NAT_SlowedByBile</defName>
    <label>slowed by bile</label>
    <description>Bile covers body and sticks to skin, making movement and manipulation much harder. Serpents' bile is fire-resistant and reacts with acid, causing severe burns. Continued exposure to tox gas results in toxic buildup and eventually death.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <maxSeverity>1</maxSeverity>
    <initialSeverity>0.001</initialSeverity>
    <everCurableByItem>false</everCurableByItem>
    <battleStateLabel>slowed by bile</battleStateLabel>
    <stages>
      <li>
        <label>slightly</label>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <setMax>0.9</setMax>
          </li>
        </capMods>
        <statOffsets>
          <MeleeCooldownFactor>0.1</MeleeCooldownFactor>
          <AimingDelayFactor>0.1</AimingDelayFactor>
        </statOffsets>
        <statFactors>
          <Flammability>0.9</Flammability>
        </statFactors>
        <damageFactors>
          <AcidBurn>1.1</AcidBurn>
        </damageFactors>
      </li>
      <li>
        <label>moderately</label>
        <minSeverity>0.5</minSeverity>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <setMax>0.8</setMax>
          </li>
        </capMods>
        <statOffsets>
          <MeleeCooldownFactor>0.25</MeleeCooldownFactor>
          <AimingDelayFactor>0.25</AimingDelayFactor>
        </statOffsets>
        <statFactors>
          <Flammability>0.75</Flammability>
        </statFactors>
        <damageFactors>
          <AcidBurn>1.3</AcidBurn>
        </damageFactors>
      </li>
      <li>
        <label>significantly</label>
        <minSeverity>0.8</minSeverity>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <setMax>0.6</setMax>
          </li>
        </capMods>
        <statOffsets>
          <MeleeCooldownFactor>0.5</MeleeCooldownFactor>
          <AimingDelayFactor>0.5</AimingDelayFactor>
        </statOffsets>
        <statFactors>
          <Flammability>0.5</Flammability>
        </statFactors>
        <damageFactors>
          <AcidBurn>1.5</AcidBurn>
        </damageFactors>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-10</severityPerDay>
      </li>
    </comps>
  </HediffDef>

</Defs>